# Copy to .env.local and fill in.

# YouTube Data API v3 key (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=

# Gemini API key (only needed once QUIZ_ENABLED is flipped on)
GEMINI_API_KEY=

# Optional overrides
# Daily YouTube quota ceiling (free tier default 10000)
YOUTUBE_DAILY_QUOTA=10000
# Where the SQLite file lives (default ./data/learnfeed.db)
LEARNFEED_DB_PATH=./data/learnfeed.db
# Secret to protect the /api/prefetch cron endpoint (optional)
PREFETCH_SECRET=
